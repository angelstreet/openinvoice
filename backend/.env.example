# OpenInvoice Backend — Environment Variables

# Database connection string (SQLite default, or PostgreSQL)
DATABASE_URL=sqlite:///./openinvoice.db

# Directory to store uploaded invoice files
UPLOADS_DIR=./uploads

# Clerk authentication (optional — leave empty to disable auth)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# MiniMax LLM API key for invoice field extraction fallback
MINIMAX_API_KEY=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3023,https://openinvoice.angelstreet.io
